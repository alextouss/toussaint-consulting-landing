# UC2 — Prospection amont, hors Salesforce (Cat 1 + tool-calling)
# LIGHT MODE — fonts bumped for PDF/print readability

direction: right

classes: {
  source: {
    shape: rectangle
    style: {
      fill: "#FAFAF5"
      stroke: "#3A342A"
      stroke-width: 1
      font-color: "#1A1410"
      font-size: 20
      border-radius: 4
    }
  }
  tool: {
    shape: rectangle
    style: {
      fill: "#FAFAF5"
      stroke: "#C97A5F"
      stroke-width: 1
      font-color: "#1A1410"
      font-size: 20
      border-radius: 4
    }
  }
  step: {
    shape: rectangle
    style: {
      fill: "#FFFFFF"
      stroke: "#C97A5F"
      stroke-width: 2
      font-color: "#1A1410"
      font-size: 20
      border-radius: 4
      bold: true
    }
  }
  crm: {
    shape: rectangle
    style: {
      fill: "#FAFAF5"
      stroke: "#8A837A"
      stroke-width: 2
      font-color: "#1A1410"
      font-size: 20
      border-radius: 4
    }
  }
}

signaux: Signaux {
  style: {
    fill: "#FDF8F3"
    stroke: "#C97A5F"
    stroke-width: 1
    stroke-dash: 3
    font-color: "#C97A5F"
    font-size: 18
    border-radius: 6
  }
  levees: "Levées · presse" { class: source }
  recrut: "Recrutements" { class: source }
  stack: "Changements stack" { class: source }
  linkedin: "Activité LinkedIn" { class: source }
}

enrich: Enrichissement {
  style: {
    fill: "#FDF8F3"
    stroke: "#C97A5F"
    stroke-width: 1
    stroke-dash: 3
    font-color: "#C97A5F"
    font-size: 18
    border-radius: 6
  }
  clearbit: "Clearbit · Apollo" { class: tool }
  builtwith: "BuiltWith" { class: tool }
  g2: "G2 · presse" { class: tool }
}

scoring: "1. Scoring\nadéquation · intention · timing" { class: step }
accroche: "2. Accroche (LLM)\nmessage d'ouverture par compte" { class: step }
revue: "3. Revue commerciale\napprouver · éditer" { class: step }
crm: "CRM\npré-rempli" { class: crm }

signaux -> enrich: { style: { stroke: "#8A837A"; stroke-width: 2 } }
enrich -> scoring: { style: { stroke: "#C97A5F"; stroke-width: 2 } }
scoring -> accroche: { style: { stroke: "#C97A5F"; stroke-width: 2 } }
accroche -> revue: { style: { stroke: "#C97A5F"; stroke-width: 2 } }
revue -> crm: { style: { stroke: "#C97A5F"; stroke-width: 2 } }
